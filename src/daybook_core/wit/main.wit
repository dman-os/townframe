package townframe:daybook;

interface types {
    type heads = list<string>;
}

interface drawer {
    use townframe:daybook-types/doc.{doc, doc-patch, facet-raw, doc-id};
    use types.{heads};

    variant get-doc-error {
        doc-not-found,
        invalid-heads(string),
    }
    
    variant update-doc-error {
        doc-not-found,
        branch-not-found,
        invalid-key(string),
        invalid-heads(string),
        invalid-patch(string),
    }
    
    get-doc-at-heads: func(
        doc-id: doc-id,
        heads: heads,
    ) -> result<doc, get-doc-error>;
    
    update-doc-at-heads: func(
        branch-name: string,
        heads: option<heads>,
        patch: doc-patch,
    ) -> result<_, update-doc-error>;
}

interface capabilities {
    use townframe:daybook-types/doc.{doc-id, facet-raw};
    use types.{heads};

    record datetime {
        seconds: u64,
        nanoseconds: u32,
    }

    variant access-error {
        denied,
        not-found,
        other(string),
    }

    variant update-doc-error {
        invalid-patch(string),
        invalid-key(string),
        other(string),
    }

    variant invoke-command-error {
        bad-request(string),
        denied(string),
        other(string),
    }

    record facet-meta {
        created-at: datetime,
    }

    record doc-meta {
        created-at: datetime,
        updated-at: list<datetime>,
    }

    flags doc-rights {
        meta-read,
        delete,
        facet-list,
    }

    flags facet-rights {
        read,
        update,
        create,
        delete,
    }

    resource doc-token {
        id: func() -> doc-id;
        rights: func() -> doc-rights;
        clone: func(downscope: option<doc-rights>) -> result<doc-token, access-error>;
        get-meta: func() -> result<doc-meta, access-error>;
        list-facets: func() -> result<list<tuple<string, facet-token>>, access-error>;
        get-facet: func(key: string) -> result<option<facet-token>, access-error>;
        list-tags: func() -> result<list<tuple<string, facet-tag-token>>, access-error>;
    }

    resource facet-token {
        key: func() -> string;
        rights: func() -> facet-rights;
        clone: func(downscope: option<facet-rights>) -> result<facet-token, access-error>;
        meta: func() -> result<facet-meta, access-error>;
        get: func() -> result<facet-raw, access-error>;
        heads: func() -> result<heads, access-error>;
        update: func(patch: facet-raw) -> result<result<_, update-doc-error>, access-error>;
    }

    resource facet-create-token {
        key: func() -> string;
        create-facet: func(data: facet-raw) -> result<facet-token, update-doc-error>;
    }

    resource facet-tag-token {
        tag: func() -> string;
        rights: func() -> facet-rights;
        list-facets: func() -> result<list<facet-token>, access-error>;
        get: func(key-id: string) -> result<option<facet-token>, access-error>;
        create: func(key-id: string, data: facet-raw) -> result<facet-token, update-doc-error>;
        get-create-token: func(key-id: string) -> result<facet-create-token, update-doc-error>;
    }

    resource command-invoke-token {
        invoke: func(request-json: string) -> result<string, invoke-command-error>;
    }

    delete-facet: func(token: facet-token) -> result<_, access-error>;
    delete-doc: func(token: doc-token) -> result<_, access-error>;
}

interface facet-routine {
    use townframe:daybook-types/doc.{doc-id};
    use types.{heads};
    use capabilities.{command-invoke-token, doc-token, facet-token, facet-tag-token};
    use sqlite-connection.{connection as sqlite-connection-token};

    record processor-invocation {
        trigger-doc-id: doc-id,
        changed-facet-keys: list<string>,
    }

    variant routine-invocation {
        processor(processor-invocation),
        command,
    }

    record doc-facet-tokens {
        doc: doc-token,
        facets: list<facet-token>,
        tags: list<facet-tag-token>,
    }

    record facet-routine-args {
        doc-id: doc-id,
        heads: heads,
        invocation: routine-invocation,
        primary-doc: doc-facet-tokens,
        config-docs: list<doc-facet-tokens>,
        command-invoke-tokens: list<tuple<string, command-invoke-token>>,
        sqlite-connections: list<tuple<string, sqlite-connection-token>>,
    }

    /// Aquire args for facet-routine-args.
    /// If the running instance isn't reconginzed to be a routine,
    /// a trap is raised to the host.
    get-args: func() -> facet-routine-args;
}

// FIXME: rename to local-state-sqlite
interface sqlite-connection {
    use townframe:sql/types.{sql-value, result-row, query-error};

    resource connection {
        query: func(query: string, params: list<sql-value>) -> result<list<result-row>, query-error>;
        query-batch: func(query: string) -> result<_, query-error>;
        sqlite-file-path: func() -> string;
    }
}

interface mltools-ocr {
    use capabilities.{facet-token};
    use townframe:mltools/ocr.{ocr-result};

    ocr-image: func(blob-facet: facet-token) -> result<ocr-result, string>;
}

interface mltools-embed {
    use capabilities.{facet-token};
    use townframe:mltools/embed.{embed-result};

    embed-text: func(text: string) -> result<embed-result, string>;
    embed-image: func(blob-facet: facet-token) -> result<embed-result, string>;
}

interface mltools-image-tools {
    use capabilities.{facet-token};

    record image-bytes-result {
        bytes: list<u8>,
        mime: string,
        width: u32,
        height: u32,
    }

    downsize-image-from-blob: func(
        blob-facet: facet-token,
        max-side: u32,
        jpeg-quality: u8,
    ) -> result<image-bytes-result, string>;
}

interface mltools-llm-chat {
    llm-chat: func(text: string) -> result<string, string>;
    llm-chat-multimodal: func(
        prompt: string,
        image-bytes: list<u8>,
        image-mime: string,
    ) -> result<string, string>;
}

world all-guest {
    import drawer;
    import capabilities;
    import facet-routine;
    import sqlite-connection;
    import mltools-ocr;
    import mltools-embed;
    import mltools-image-tools;
    import mltools-llm-chat;
    import wasi:filesystem/preopens@0.2.6;
}
