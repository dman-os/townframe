mod interlude {
    pub use utils_rs::prelude::*;
}

use crate::interlude::*;

use crate::repo::{DocumentId, PeerId};
use crate::sync::machine::SyncMachine;
use crate::sync::protocol::{PartitionId, PeerKey};

use std::collections::{BTreeMap, BTreeSet};
use std::time::{Duration, Instant};

#[derive(Debug, Clone)]
pub struct BigSyncConfig {
    pub max_active_workers: usize,
    pub min_doc_worker_floor: usize,
    pub min_blob_worker_floor: usize,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, PartialOrd, Ord)]
pub struct WorkerId(pub u64);

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, PartialOrd, Ord)]
pub struct TaskId(pub u64);

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, PartialOrd, Ord)]
pub struct TaskRunId(pub u64);

#[derive(Debug, Clone, PartialEq, Eq, Hash, PartialOrd, Ord)]
pub enum BackendKind {
    Doc,
    Blob,
    Rsync,
    Custom(Arc<str>),
}

#[derive(Debug, Clone, PartialEq, Eq, Hash, PartialOrd, Ord)]
pub enum WorkerKind {
    SyncBackend(BackendKind),
    Maintenance(Arc<str>),
    Custom(Arc<str>),
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, PartialOrd, Ord)]
pub enum PeerPhase {
    Disconnected,
    Bootstrapping,
    Live,
    Draining,
    Stopped,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, PartialOrd, Ord)]
pub enum TaskScope {
    PerPeer,
    PerItem,
    FanoutToRequesters,
    Global,
}

#[derive(Debug, Clone, PartialEq, Eq, Hash, PartialOrd, Ord)]
pub enum CompletionScope {
    Peer,
    Requesters,
    Peers(BTreeSet<PeerId>),
    Global,
}

#[derive(Debug, Clone, PartialEq, Eq, Hash, PartialOrd, Ord)]
pub enum TaskTarget {
    Document {
        peer_id: PeerId,
        document_id: DocumentId,
    },
    Blob {
        hash: Arc<str>,
    },
    Partition {
        partition_id: PartitionId,
    },
    Custom {
        label: Arc<str>,
    },
}

#[derive(Debug, Clone)]
pub struct TaskRequest {
    pub backend: BackendKind,
    pub target: TaskTarget,
    pub requested_by: BTreeSet<PeerId>,
    pub partitions: BTreeSet<PartitionId>,
}

#[derive(Debug, Clone)]
pub struct TaskPlan {
    pub backend: BackendKind,
    pub worker_kind: WorkerKind,
    pub task_scope: TaskScope,
    pub completion_scope: CompletionScope,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, PartialOrd, Ord)]
pub enum TaskStatus {
    Pending,
    Queued,
    Running {
        worker_id: WorkerId,
        run_id: TaskRunId,
    },
    BackingOff {
        due_at: Instant,
    },
    Blocked,
    Completed,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, PartialOrd, Ord)]
pub enum WorkerStatus {
    Starting,
    Running,
    Stopping,
    Exited,
}

#[derive(Debug, Clone)]
pub struct RetryState {
    pub attempt_no: usize,
    pub last_backoff: Duration,
    pub last_attempt_at: Instant,
}

#[derive(Debug, Clone)]
pub struct PeerSyncCounters {
    pub bootstrap_synced_docs: u64,
    pub bootstrap_remaining_docs: u64,
    pub doc_pending_docs: u64,
    pub blob_pending_blobs: u64,
}

#[derive(Debug, Clone)]
pub struct PeerState {
    pub peer_id: PeerId,
    pub peer_key: PeerKey,
    pub endpoint_addr: Option<iroh::EndpointAddr>,
    pub desired_partitions: BTreeSet<PartitionId>,
    pub active_partitions: BTreeSet<PartitionId>,
    pub phase: PeerPhase,
    pub counters: PeerSyncCounters,
    pub emitted_full_synced: bool,
    pub session_generation: u64,
    pub fully_synced_partitions: BTreeSet<PartitionId>,
}

#[derive(Debug, Clone)]
pub struct PartitionState {
    pub kind: BackendKind,
    pub peers: BTreeSet<PeerId>,
}

#[derive(Debug, Clone)]
pub struct TaskState {
    pub task_id: TaskId,
    pub request: TaskRequest,
    pub plan: Option<TaskPlan>,
    pub status: TaskStatus,
    pub retry: RetryState,
    pub assigned_worker: Option<WorkerId>,
    pub run_id: Option<TaskRunId>,
    pub requested_peers: BTreeSet<PeerId>,
    pub blocked_reason: Option<Arc<str>>,
}

#[derive(Debug, Clone)]
pub struct WorkerState {
    pub worker_id: WorkerId,
    pub worker_kind: WorkerKind,
    pub task_id: Option<TaskId>,
    pub run_id: Option<TaskRunId>,
    pub status: WorkerStatus,
    pub started_at: Option<Instant>,
}

#[derive(Debug, Clone)]
pub struct TaskClaim {
    pub task_id: TaskId,
    pub worker_id: WorkerId,
    pub run_id: TaskRunId,
    pub plan: TaskPlan,
}

#[derive(Debug, Clone)]
pub struct WorkerClaim {
    pub worker_id: WorkerId,
    pub task_id: TaskId,
    pub run_id: TaskRunId,
}

#[derive(Debug, Clone)]
pub struct PeerSnapshot {
    pub peer_id: PeerId,
    pub peer_key: PeerKey,
    pub phase: PeerPhase,
    pub emitted_full_synced: bool,
    pub fully_synced_partitions: BTreeSet<PartitionId>,
    pub counters: PeerSyncCounters,
}

#[derive(Debug, Clone)]
pub struct TaskSnapshot {
    pub task_id: TaskId,
    pub backend: BackendKind,
    pub status: TaskStatus,
    pub assigned_worker: Option<WorkerId>,
}

#[derive(Debug, Clone)]
pub struct WorkerSnapshot {
    pub worker_id: WorkerId,
    pub worker_kind: WorkerKind,
    pub status: WorkerStatus,
    pub task_id: Option<TaskId>,
}

#[derive(Debug, Clone)]
pub struct BigSyncSnapshot {
    pub peers: Vec<PeerSnapshot>,
    pub tasks: Vec<TaskSnapshot>,
    pub workers: Vec<WorkerSnapshot>,
}

#[derive(Debug, Clone)]
pub enum BigSyncAction {
    SpawnWorker {
        worker_id: WorkerId,
        task_id: TaskId,
        run_id: TaskRunId,
    },
    StopWorker {
        worker_id: WorkerId,
    },
    ScheduleTask {
        task_id: TaskId,
        due_at: Instant,
    },
    ClearTask {
        task_id: TaskId,
    },
    MarkPeerReady {
        peer_id: PeerId,
    },
    MarkPeerStale {
        peer_id: PeerId,
    },
}

pub trait BigSyncBackend: Send + Sync + 'static {
    fn kind(&self) -> BackendKind;

    fn classify(&self, request: &TaskRequest) -> Res<TaskPlan>;
}

