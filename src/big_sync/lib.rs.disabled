#[allow(dead_code)]
pub struct BigSyncMachine {
    sync: SyncMachine,
    config: BigSyncConfig,
    backends: BackendRegistry,
    peers: BTreeMap<PeerId, PeerState>,
    partitions: BTreeMap<PartitionId, PartitionState>,
    tasks: TaskRegistry,
    workers: WorkerRegistry,
    full_sync_waiters: Vec<BigSyncWaiter>,
    next_worker_id: u64,
    next_task_id: u64,
    next_run_id: u64,
}

#[derive(Debug, Clone)]
pub struct BigSyncWaiter {
    pub remaining_peers: BTreeSet<PeerId>,
    pub required_partitions: BTreeSet<PartitionId>,
}

